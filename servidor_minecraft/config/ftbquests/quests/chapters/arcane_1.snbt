		{
			title: "The Wicked Sign"
			icon: "quark:purple_candle"
			x: -10.0d
			y: 3.0d
			shape: "square"
			subtitle: "Team up with The Evil. Left Click for more info"
			description: [
				"In order to further advance, you'll have to share The Ars Ecclesia (which is one of the Books included in the Akashic Tome you received at the beginning) with a Witch. She will grant your The Wicked Sign, which will be essential down the road."
				""
				"Task: Throw The Ars Ecclesia at a witch."
				""
				"Note: Keep in mind that this quest is here to keep track of what you need to do. Finishing it, doesn't actually mean you did what you HAD TO."
				""
				"{image:kubejs:textures/eidolon/example3.png width:100 height:170 align:1}"
				"The example above shows a witch in the process of writing the wicked sign in the Ars Ecclesia."
			]
			dependencies: ["6EC2AAB1C3022A4E"]
			id: "2456A6DB1ADA4325"
			tasks: [{
				id: "153E78E2D5339E96"
				type: "checkmark"
				title: "Give The Ars Ecclesia to a witch."
				icon: "eidolon:codex"
			}]
		}
		{
			x: -10.0d
