		{
			x: 3.5d
			y: 3.5d
			subtitle: "Glass Fiber at its Finest. Left Click for more info"
			description: [
				"The Dense Smart Cable can carry 32 channels unlike standard cable which can only carry 8, however it doesn't support buses so you must first step down from dense to a smaller cable (such as Fluix ME Glass Cable or Fluix ME Smart Cable) before using buses or panels."
				""
				"Shows load similarly to Fluix ME Smart Cable, with each line lit representing four channels in use."
			]
			dependencies: ["6A1D5E5A7EB1F570"]
			id: "3D919F1F9FA991F7"
			tasks: [{
