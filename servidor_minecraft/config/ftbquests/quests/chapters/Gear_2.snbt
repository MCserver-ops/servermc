		{
			title: "Capacitors"
			x: 9.5d
			y: -8.5d
			shape: "gear"
			subtitle: "Energy currently generates far too slowly to just be wasted. A Capacitor will allow you to store excess energy. These capacitors can hold 100k, 1M and 4M RF and are entirely made in a Crafting Table. Additionally, they're kinda cheaper"
			dependencies: ["1F1994D8C11FAB3D"]
			id: "10CAC510498E8582"
			tasks: [
				{
					id: "3F2B399F6E3190E4"
