		{
			title: "The Chaos Island"
			icon: "structurize:black_clay_shingle_slab"
			x: 5.5d
			y: -6.5d
			shape: "square"
			subtitle: "No risk, no reward. Left Click for more info"
			description: [
				"Even tho you can physically finish this quest while you're in the 3rd Age, you should wait until the 4th one, and you obtain a Chest Piece from Draconic Evolution."
				""
				"Finding a Chaos Island withtout propper protection, will 100% result into your instant Death."
				""
				"Now, the Chaos Islands can be found in The End, at every interval of 10000 blocks from the Main Island. It is the home of the Chaos Guardian. The Strongest Boss Modded Minecraft has ever Seen."
				""
				"While you can go to every combination of 10000 coordonates, for now, go towards X:10000 Y:0."
			]
			dependencies: [
				"420B786D7ECD0706"
				"78ECF24A2D1EB21A"
			]
			id: "3767C798A2FF9D46"
			tasks: [{
				id: "41908E07E47E322B"
				type: "location"
				title: "Reach X: 10000 Y: 100 Z: 0"
