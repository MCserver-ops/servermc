					id: "custommachinery:custom_machine_item"
					Count: 1b
					tag: {
						machine: "custommachinery:metal_compressor"
					}
				}
				match_nbt: true
			}]
		}
		{
			title: "Building Rockets"
			x: 8.0d
			y: 11.0d
			shape: "square"
			subtitle: "To the realms of space. Left Click for more info"
			description: [
				"This will be one of the first quests regaring Space exploration. Why do you need to go into Space, you're asking? That's quite simple. There are a few needed materials which you'll only find on other planets. To reach those planets, you'll need a rocket. How do you get that? Well, that's where the Nasa Workbench comes in."
				""
				"This machine will take multiple rocket pieces and assemble them into mighty rockets."
			]
			dependencies: [
				"46B7A05259CC0513"
				"5984E05C451F1AF2"
			]
			dependency_requirement: "all_started"
