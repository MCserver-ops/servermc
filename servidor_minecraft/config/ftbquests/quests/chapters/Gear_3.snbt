				item: "mekanism:osmium_compressor"
			}]
		}
		{
			x: 9.5d
			y: 8.0d
			shape: "square"
			subtitle: "Dense steel keeps you alive in Space. Left Click for more info"
			description: [
				"This will be one of the first quests regaring your journey into Space. Yes, you heard that right, you're going to Space. Since the environment there will constantly try to kill you, a strong, very dense verison of your regular steel will be required there."
				""
				"Fortunately, this machine is exactly what you need. The Metal Compressor will take certain metals and compress them until they're dense enough to withstand the vacuum of Space."
				""
				"This machine can accept up to 4 AE2 Acceleration Cards as upgrades."
			]
			dependencies: ["5984E05C451F1AF2"]
			dependency_requirement: "all_started"
			id: "1A870097D55C3137"
			tasks: [{
