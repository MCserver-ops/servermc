		{
			title: "Making Rocket Fuel"
			icon: {
				id: "custommachinery:custom_machine_item"
				Count: 1b
				tag: {
					machine: "custommachinery:fuel_mixing_unit"
				}
			}
			x: 9.0d
			y: 11.0d
			shape: "square"
			subtitle: "Kerosene? Neh, doesn't exist in this universe. Left Click for more info"
			description: [
				"The Fuel Assembly Unit will allow you to combine Refined Fuel, Gasoline and Liquid Oxygen into a potent substance which can be used to power Rockets."
				""
				"After you have the fuel, you'll need to Shift Right-Click the Rocket to open its fuel tank. Place a bucket of fuel and wait for the tank to fill up. When it's full, you can start your journey into space."
			]
