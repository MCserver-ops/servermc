		{
			title: "Molecular Exchanger"
			x: 2.5d
			y: 7.0d
			subtitle: "Early item exchanging can be obtained through the use of this machine. Left Click for more info"
			description: [
				"The Antiprotonic Nucleosynthesizer is a machine added by Mekanism. Its main use is to take items, small amounts of Antimatter and fair amounts of power to obtain new items."
				""
				"With it, you can obtain Diamonds from Coal, Iron Ingots from Tin, and more. Use JEI to see what other transmutations you can perform with it."
			]
			dependencies: ["593F074B73FF3116"]
