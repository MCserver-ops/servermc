	quests: [
		{
			title: "Desert Adept"
			icon: "atum:scarab"
			x: -4.0d
			y: 1.0d
			shape: "square"
			subtitle: "Ok, so you wanna go to Atum? You'll need a Scarab to light up the Portal. Left Click for more info"
			description: [
				"Since you're here, it must mean that you're ready to enter Atum. If you're not, we have no idea why you're here. Go play with Create or something :/ "
				""
				"Now, considering that you're ready, let's see how you make the portal for this dimension. Things are not too complicated. Just 49 piesces of Sandstone and a pool of Water will be required for this task."
				""
				"Below, you can see how the portal frame should look like:"
				""
				"{image:kubejs:textures/atum2/portal_example.png width:100 height:100 align:1}"
				""
				"Fill it with water, then throw the Scarab in it. The Portal will light up and this quest will allow you to enter Atum. Isn't that great? ☻"
			]
			hide_dependency_lines: true
			dependencies: ["4A3AF0119A31CFF3"]
			size: 2.0d
			id: "347EFD1D11627798"
			tasks: [{
				id: "5523ED7C19A0C660"
				type: "checkmark"
				title: "I have the Scarab!"
			}]
			rewards: [{
				id: "3C38E63A232BAD03"
				type: "command"
				title: "Adapt To Enter Atum"
				icon: "atum:idol_of_labor"
				command: "/thitemstages add @p atum_2"
				player_command: false
			}]
