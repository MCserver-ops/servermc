				item: "projecte:interdiction_torch"
			}]
		}
		{
			x: 4.0d
			y: 2.5d
			shape: "gear"
			subtitle: "The Repair Talisman is an item added by ProjectE. Like its name might suggest, it has the ability to repair items while it is being held in your inventory. You can also place it in an Alchemical Chest to use its repairing properties, but regular Chests won't work. Finally, the Talisman can also be placed on a Dark Matter Pedestal and it will repair the items from the inventory of the player that's nearby"
			dependencies: ["75EB00BEED4C74E3"]
			id: "641C8CCE4D66897F"
			tasks: [{
